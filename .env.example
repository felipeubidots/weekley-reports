# === SHORTCUT ===
# Obtener token en: https://app.shortcut.com/settings/api-tokens
SHORTCUT_API_TOKEN=your_shortcut_api_token_here
SHORTCUT_API_URL=https://api.app.shortcut.com

# === SLACK ===
# Obtener token en: https://api.slack.com/apps
SLACK_BOT_TOKEN=your_slack_bot_token_here
# Obtener Channel ID: Click derecho en canal → "View channel details"
SLACK_REPORT_CHANNEL_ID=your_slack_channel_id_here
SLACK_API_URL=https://slack.com/api

# === REPORT CONFIGURATION ===
OVERDUE_DAYS_THRESHOLD=7
INACTIVE_CHANNELS_DAYS=7

# === LOGGING ===
LOG_LEVEL=info

# === OPTIONAL ===
NODE_ENV=production
REPORT_OUTPUT_DIR=./reports
